{
  "version": 1,
  "author": "Lab 5.2 — DS18B20 + 5V relay (active-LOW) ⇒ DC cooling fan. Controller posts a 0..100% duty; the actuator slices it across a configurable TPC window (default 2 s) so the binary relay imitates a continuous fan speed. ON-OFF mode is the degenerate case where duty is always 0 or 100. The motor here is driven through COM/NO so it spins ONLY when the relay coil is energised — match this with the firmware's `polarity low` (default).",
  "editor": "wokwi",
  "parts": [
    { "type": "wokwi-arduino-mega", "id": "mega", "top": 80, "left": 30, "attrs": {} },
    {
      "type": "wokwi-ds18b20",
      "id": "temp1",
      "top": -90,
      "left": 600,
      "attrs": { "temperature": "30" }
    },
    {
      "type": "wokwi-resistor",
      "id": "rpu",
      "top": -50,
      "left": 720,
      "rotate": 90,
      "attrs": { "value": "4700", "label": "4.7k pull-up" }
    },
    {
      "type": "wokwi-relay-module",
      "id": "rly1",
      "top": -210,
      "left": 200,
      "attrs": {}
    },
    {
      "type": "wokwi-dc-motor",
      "id": "motor1",
      "top": 230,
      "left": 350,
      "attrs": { "label": "DC fan / motor" }
    },
    {
      "type": "wokwi-led",
      "id": "ledOn",
      "top": 360,
      "left": 480,
      "attrs": { "color": "green", "label": "Relay ON indicator" }
    },
    {
      "type": "wokwi-resistor",
      "id": "rled",
      "top": 360,
      "left": 400,
      "rotate": 90,
      "attrs": { "value": "220" }
    },
    {
      "type": "wokwi-lcd1602",
      "id": "lcd1",
      "top": 100,
      "left": -320,
      "attrs": { "pins": "i2c", "i2cAddress": "0x27", "label": "I2C LCD 0x27" }
    }
  ],
  "connections": [
    [ "temp1:VCC", "mega:5V",   "red",   [ "v0" ] ],
    [ "temp1:GND", "mega:GND.1","black", [ "v0" ] ],
    [ "temp1:DQ",  "mega:5",    "green", [ "v0" ] ],
    [ "rpu:1",     "temp1:DQ",  "",      [ "v0" ] ],
    [ "rpu:2",     "mega:5V",   "red",   [ "v0" ] ],

    [ "rly1:VCC",  "mega:5V",   "red",   [ "v0" ] ],
    [ "rly1:GND",  "mega:GND.2","black", [ "v0" ] ],
    [ "rly1:IN",   "mega:8",    "yellow",[ "v0" ] ],
    [ "rly1:COM",  "mega:5V",   "red",   [ "v0" ] ],
    [ "rly1:NO",   "motor1:1",  "orange",[ "v0" ] ],
    [ "motor1:2",  "mega:GND.3","black", [ "v0" ] ],

    [ "rled:1",    "rly1:NO",   "orange",[ "v0" ] ],
    [ "rled:2",    "ledOn:A",   "",      [ "v0" ] ],
    [ "ledOn:C",   "mega:GND.4","black", [ "v0" ] ],

    [ "lcd1:VCC",  "mega:5V",   "red",   [ "v0" ] ],
    [ "lcd1:GND",  "mega:GND.5","black", [ "v0" ] ],
    [ "lcd1:SDA",  "mega:20",   "blue",  [ "v0" ] ],
    [ "lcd1:SCL",  "mega:21",   "blue",  [ "v0" ] ]
  ],
  "dependencies": {}
}
